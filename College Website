#include <stdio.h>

int main() {
    FILE *fp;
    char name[50];
    int age;
    char course[50];

    fp = fopen("data.txt", "a");

    if (fp == NULL) {
        printf("Error opening file!\n");
        return 1;
    }

    printf("Enter Student Name: ");
    scanf("%s", name);

    printf("Enter Age: ");
    scanf("%d", &age);

    printf("Enter Course: ");
    scanf("%s", course);

    fprintf(fp, "Name: %s | Age: %d | Course: %s\n", name, age, course);

    fclose(fp);

    printf("Data Saved Successfully!\n");

    return 0;
}
